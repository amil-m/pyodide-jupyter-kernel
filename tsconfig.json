{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020", "WebWorker", "DOM"],
    "outDir": "out",
    "sourceMap": true,
    "strict": false,
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": [
    "src/**/*",
    "webview/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test-web"
  ]
}
