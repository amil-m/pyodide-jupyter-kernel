{
  "name": "pyodide-jupyter-kernel",
  "displayName": "Pyodide Jupyter Kernel",
  "description": "Run Jupyter notebooks with Python in the browser using Pyodide",
  "version": "0.1.0",
  "publisher": "Amil Mohanan",
  "repository": {
    "type": "git",
    "url": "https://github.com/amil-m/pyodide-jupyter-kernel"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Notebooks"
  ],
  "keywords": [
    "jupyter",
    "python",
    "pyodide",
    "notebook",
    "webassembly"
  ],
  "browser": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pyodide-kernel",
          "title": "Pyodide Kernel",
          "icon": "$(snake)"
        }
      ]
    },
    "views": {
      "pyodide-kernel": [
        {
          "type": "webview",
          "id": "pyodide-kernel.statusView",
          "name": "Kernel Status"
        }
      ]
    }
  },
  "activationEvents": [
    "onNotebook:jupyter-notebook"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test-web": "npx @vscode/test-web@latest --browserType=chromium --extensionDevelopmentPath=. .",
    "open-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.x",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-web": "^0.0.50",
    "eslint": "^8.54.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {}
}
